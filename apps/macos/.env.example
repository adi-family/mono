# Copy to .env (gitignored) and fill in. Used by release.sh for Developer ID
# signing + notarization of ADI.dmg.
TEAM_ID=            # Apple Developer team ID, e.g. 752556J5V6
AC_USER=            # Apple ID email used for notarization
AC_PASS=            # app-specific password from appleid.apple.com
# Optional:
# SIGN_ID="Developer ID Application: NAME (TEAMID)"   # else auto-found for TEAM_ID
