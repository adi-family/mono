package adi:workforce;

interface host {
    call-tool: func(name: string, args-json: string) -> result<string, string>;
    call-llm: func(system: string, user: string) -> result<string, string>;
    log: func(level: string, message: string);
    get-context: func(key: string) -> option<string>;
    read-file: func(path: string) -> result<string, string>;
    write-file: func(path: string, content: string) -> result<_, string>;

    /// Create a loop session on the host. Given a full loop config
    /// (name, runner, tools, filesystem, systemMessage), the host
    /// instantiates tools, resolves the filesystem, builds the LLM
    /// backend, and returns a session handle that can drive
    /// `loop-llm` / `loop-tool` / `loop-finish`. All expensive setup
    /// (tool creation, sandbox init, system prompt construction)
    /// happens here.
    ///
    /// Returns JSON: { "id": string, "maxTurns": number, "maxTokens": number,
    /// "systemPrompt": string, "workdir": string }
    loop-init: func(config-json: string) -> result<string, string>;

    /// Run one LLM turn for a session. `turns-json` is the full
    /// conversation history so far (same wire shape as Anthropic
    /// Messages). Returns the assistant's new turn + metadata.
    ///
    /// Returns JSON: { "blocks": [...], "stopReason": string,
    /// "usage": { "inputTokens": number, "outputTokens": number,
    /// "cacheCreationInputTokens": number, "cacheReadInputTokens": number } }
    loop-llm: func(session-id: string, turns-json: string) -> result<string, string>;

    /// Execute one tool call via a session's tool list. The loop
    /// driver (SDK) is responsible for appending the result to the
    /// conversation as a tool_result block.
    loop-tool: func(session-id: string, tool-name: string, args-json: string) -> result<string, string>;

    /// Tear down a session (release filesystem, etc.).
    loop-finish: func(session-id: string);

    /// Subscribe to a named event source with config
    subscribe: func(name: string, config-json: string);
}

world loop-script {
    import host;

    /// Return this WASM's employee registration as JSON.
    /// Host calls once right after instantiation, before any other export.
    /// Shape: { name: string, description?: string, labels?: { [k: string]: string } }
    /// Empty string means "not registered" — host rejects the module.
    export get-registration: func() -> string;

    /// Runtime entry — host calls this once after instantiation. Any call into
    /// host imports (subscribe, call-tool, …) must happen here or later.
    /// Wizer snapshotting at componentize time means module top-level code
    /// CANNOT call host imports.
    export main: func();

    /// Host dispatches events here. SDK routes to the right callback.
    export dispatch: func(handler: string, data-json: string) -> string;

    /// Lifetime hooks (SDK internal, host calls during loop)
    export on-loop-start: func() -> string;
    export on-turn-start: func(turn: u32, turns-json: string) -> string;
    export on-turn-end: func(turn: u32, response-json: string, turns-json: string) -> string;
    export before-tool-call: func(tool-name: string, args-json: string) -> string;
    export after-tool-call: func(tool-name: string, args-json: string, tool-result: string) -> string;
    export on-loop-end: func(result-json: string) -> string;
}
