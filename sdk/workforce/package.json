    },
    "./wit": "./workforce.wit"
  },
  "files": [
    "index.ts",
    "index.d.ts",
    "host.d.ts",
    "workforce.wit",
    "build.mjs"
  ],
  "peerDependencies": {
    "esbuild": ">=0.20.0",
    "@bytecodealliance/jco": ">=1.0.0"
  },
  "license": "BSL-1.0"
