{
  "name": "@adi-family/workforce-sdk",
  "version": "0.6.0",
  "description": "Adi Workforce SDK — typed plugin system for WASM employee configs",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.d.ts",
  "bin": {
    "workforce-build": "./build.mjs"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
